# QueryForge production environment template.
# Copy this file to your deployment secret manager / environment variables.
# Do not commit real secrets.

# ============ 应用 ============
APP_ENV=production
PROJECT_NAME=QueryForge Text-to-SQL
VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=false
ALLOWED_ORIGINS=https://your-frontend.example.com
PUBLIC_QUERY_ENABLED=false
APP_WORKERS=1

# ============ LLM（OpenAI compatible endpoint）============
LLM_PROVIDER=openai
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENCY=5
OPENAI_API_KEY=__REQUIRED__
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ DashScope embedding / rerank ============
DASHSCOPE_API_KEY=__REQUIRED__
DASHSCOPE_MAX_CONCURRENCY=20

EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=10

RERANK_ENABLED=true
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL=gte-rerank-v2
RERANK_TOP_N=8

# ============ 应用元数据库（可读写：users/sessions/messages/RAG/checkpoint/cache）============
POSTGRES_HOST=app-postgres.internal
POSTGRES_PORT=5432
POSTGRES_DB=queryforge
POSTGRES_USER=queryforge_app
POSTGRES_PASSWORD=__REQUIRED_STRONG_PASSWORD__
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# ============ 业务查询库（只读账号：仅允许 SELECT）============
QUERY_POSTGRES_HOST=business-readonly.internal
QUERY_POSTGRES_PORT=5432
QUERY_POSTGRES_DB=business_db
QUERY_POSTGRES_USER=queryforge_readonly
QUERY_POSTGRES_PASSWORD=__REQUIRED_STRONG_PASSWORD__
QUERY_POSTGRES_POOL_MIN=1
QUERY_POSTGRES_POOL_MAX=10

# ============ Redis ============
REDIS_ENABLED=true
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=__REQUIRED_IF_YOUR_REDIS_REQUIRES_AUTH__
CACHE_TTL_SECONDS=600

# ============ 语义近似缓存 ============
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.97
SEMANTIC_CACHE_TTL_SECONDS=3600

# ============ 熔断器 ============
CIRCUIT_FAIL_THRESHOLD=5
CIRCUIT_RESET_SECONDS=30

# ============ RAG ============
RETRIEVE_TOP_K=20
RRF_K=60
QUERY_EXPANSION_ENABLED=false
DOC_CONTEXT_ENABLED=false
FEWSHOT_TOP_K=3
FEWSHOT_CROSS_DB=false
RETRIEVAL_BACKEND=pg_jieba

# ============ Text-to-SQL ============
SQL_DIALECT=postgres
SQL_MAX_RETRY=2
SQL_EXEC_TIMEOUT_SECONDS=10
SQL_MAX_ROWS=200
QUERY_MAX_INFLIGHT=20
QUERY_INFLIGHT_BACKEND=redis
QUERY_INFLIGHT_TTL_SECONDS=120
HISTORY_TURNS=4
EVAL_SKIP_ANSWER_LLM=false

# ============ Langfuse ============
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=__REQUIRED__
LANGFUSE_SECRET_KEY=__REQUIRED__
LANGFUSE_HOST=https://cloud.langfuse.com

# ============ JWT ============
JWT_SECRET=__REQUIRED_AT_LEAST_32_BYTES_RANDOM_SECRET__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============ 入库安全 ============
INGEST_MAX_CHARS=200000

# ============ 限流 ============
RATE_LIMIT_QUERY=100/second
RATE_LIMIT_QUERY_GLOBAL=300/second
RATE_LIMIT_DEFAULT=1000/minute

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs
