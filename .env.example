# ============ 应用 ============
APP_ENV=development                       # development | staging | production | test
PROJECT_NAME=QueryForge Text-to-SQL
VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=true
ALLOWED_ORIGINS=*
PUBLIC_QUERY_ENABLED=true                 # 生产建议 false，单轮 /query 需要鉴权；eval/smoke 可打开
APP_WORKERS=1                             # Docker app worker 数；默认 1，多实例优先用多容器扩容

# ============ LLM（默认示例：通义千问，走 OpenAI 兼容接口；换模型只改这里）============
LLM_PROVIDER=openai
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENCY=5                    # 全局 LLM 并发闸，保护模型 API
OPENAI_API_KEY=__YOUR_OPENAI_COMPATIBLE_API_KEY__
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 阿里云百炼 DashScope（embedding + rerank 共用一个 key）============
DASHSCOPE_API_KEY=__YOUR_DASHSCOPE_API_KEY__

# ============ Embedding（Qwen text-embedding-v4，OpenAI 兼容）============
# 也可以换成工作空间专属 endpoint：https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1536                        # 必须与建表/索引维度一致；text-embedding-v4 支持 1536
EMBEDDING_BATCH_SIZE=10                   # DashScope 单次批量上限

# ============ Reranker（Qwen gte-rerank，DashScope 原生 API）============
RERANK_ENABLED=true
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL=gte-rerank-v2
RERANK_TOP_N=8

# ============ PostgreSQL（pgvector + pg_jieba）============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=queryforge
POSTGRES_USER=queryforge
POSTGRES_PASSWORD=queryforge
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# ============ 业务查询库（生产建议独立只读账号；未配置则复用 POSTGRES_*）============
QUERY_POSTGRES_HOST=
QUERY_POSTGRES_PORT=5432
QUERY_POSTGRES_DB=
QUERY_POSTGRES_USER=
QUERY_POSTGRES_PASSWORD=
QUERY_POSTGRES_POOL_MIN=1
QUERY_POSTGRES_POOL_MAX=10

# ============ Redis（限流 + 语义缓存）============
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=600

# ============ 语义近似缓存（默认关闭，text-to-sql 精确性优先）============
SEMANTIC_CACHE_ENABLED=false              # 仅高并发可容忍近似场景再开
SEMANTIC_CACHE_THRESHOLD=0.97
SEMANTIC_CACHE_TTL_SECONDS=3600

# ============ RAG 检索参数 ============
RETRIEVE_TOP_K=20                         # 每路召回条数
RRF_K=60                                  # RRF 融合常数
QUERY_EXPANSION_ENABLED=false             # 多查询扩展；需离线 A/B 验证后再开
DOC_CONTEXT_ENABLED=false                 # 是否检索业务文档；benchmark/默认生产建议关闭
FEWSHOT_TOP_K=3
FEWSHOT_CROSS_DB=false                    # 多租户/多库生产建议 false；CSpider 跨域评测可设 true

# ============ Text-to-SQL 链路 ============
SQL_MAX_RETRY=2                           # 自纠错最大重试次数
SQL_EXEC_TIMEOUT_SECONDS=10
SQL_MAX_ROWS=200
QUERY_MAX_INFLIGHT=20                     # /query 在途请求并发上限，超过直接 503
QUERY_INFLIGHT_BACKEND=redis              # redis | local；生产必须 redis，支持多实例共享并发
QUERY_INFLIGHT_TTL_SECONDS=120            # 请求异常退出后的并发槽兜底过期时间
SQL_DIALECT=sqlite                        # CSpider 目标库为 sqlite；生产可切 postgres
CSPIDER_DB_DIR=/path/to/CSpider/database
HISTORY_TURNS=4                           # 改写时回看的历史轮数（图①）
EVAL_SKIP_ANSWER_LLM=false                # 评测脚本会自动打开，跳过答案总结 LLM

# ============ Langfuse 链路追踪（langfuse SDK v3/v4）============
# 自托管：make langfuse-up 后打开 LANGFUSE_HOST 注册→建项目→把下面 key 填上
# 云端：LANGFUSE_HOST 改为 https://cloud.langfuse.com（欧区）或 https://us.cloud.langfuse.com（美区）
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=__YOUR_LANGFUSE_PUBLIC_KEY__
LANGFUSE_SECRET_KEY=__YOUR_LANGFUSE_SECRET_KEY__
LANGFUSE_HOST=http://localhost:3000

# ============ LangSmith（不用；本项目使用 Langfuse）============
LANGCHAIN_TRACING_V2=false
LANGSMITH_TRACING=false
LANGCHAIN_ENDPOINT=
LANGSMITH_ENDPOINT=

# ============ 鉴权（JWT）============
JWT_SECRET=change-me-in-production        # 生产务必改成随机长串
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============ 入库安全 ============
INGEST_MAX_CHARS=200000

# ============ 限流 ============
RATE_LIMIT_QUERY=100/second               # 目标并发：每秒 100 次
RATE_LIMIT_QUERY_GLOBAL=300/second        # 全局 /query 限流，防止多用户叠加打爆下游
RATE_LIMIT_DEFAULT=1000/minute

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_FORMAT=json                           # json | console
LOG_DIR=logs

# ============ 评测（Phase 4）============
CSPIDER_ROOT=/path/to/CSpider
EVAL_LLM_MODEL=qwen-max
